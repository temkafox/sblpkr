{
  "name": "@neonpoker/server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "pnpm --filter @neonpoker/shared --filter @neonpoker/poker-core build && nest start --watch",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@neonpoker/poker-core": "workspace:*",
    "@neonpoker/shared": "workspace:*",
    "@nestjs/common": "^11.1.2",
    "@nestjs/core": "^11.1.2",
    "@nestjs/platform-express": "^11.1.2",
    "@nestjs/platform-socket.io": "^11.1.21",
    "@nestjs/websockets": "^11.1.21",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.21",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.29",
    "socket.io-client": "^4.8.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
