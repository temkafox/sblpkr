{
  "name": "neonpoker",
  "private": true,
  "version": "0.0.0",
  "description": "NEONPOKER — desktop neon cyberpunk Texas Hold'em poker",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:web": "pnpm --filter @neonpoker/web dev",
    "build:packages": "pnpm --filter @neonpoker/shared --filter @neonpoker/poker-core build",
    "dev:server": "pnpm build:packages && pnpm --filter @neonpoker/server dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}
